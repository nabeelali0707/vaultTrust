rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user role from claims matches role
    function hasRole(role) {
      return request.auth != null && request.auth.token.role == role;
    }

    // users/{uid}
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // freelancerProfiles/{uid}
    match /freelancerProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // connectedSources/{uid}/**
    match /connectedSources/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // transactions/{uid}/**
    match /transactions/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // incomeScores/{uid}
    match /incomeScores/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Only written via Admin SDK scoring calculations
    }

    // consents/{consentId}
    match /consents/{consentId} {
      // Freelancer owner can read/write their consent
      allow read: if request.auth != null && request.auth.uid == resource.data.freelancerId;
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.freelancerId;
      allow delete: if false;

      // Bank officer can read (never write) consents if active and assigned to them
      allow read: if request.auth != null && 
                  hasRole('BANK_OFFICER') && 
                  request.auth.uid == resource.data.bankId && 
                  resource.data.status == 'ACTIVE';
    }

    // consentLedger/{consentId}/entries/{entryId}
    match /consentLedger/{consentId}/entries/{entryId} {
      // Rejects direct client writes entirely (ledger is append-only via Admin SDK)
      allow write: if false;
      
      // Read is only allowed under the same conditions as the parent consent
      allow read: if request.auth != null && (
        request.auth.uid == get(/databases/$(database)/documents/consents/$(consentId)).data.freelancerId ||
        (hasRole('BANK_OFFICER') && 
         request.auth.uid == get(/databases/$(database)/documents/consents/$(consentId)).data.bankId && 
         get(/databases/$(database)/documents/consents/$(consentId)).data.status == 'ACTIVE')
      );
    }
  }
}
