# =============================================================================
# VaultTrust — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control — it is already in .gitignore.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# All other variables are server-only (used in API Route Handlers only).
# =============================================================================


# -----------------------------------------------------------------------------
# FIREBASE — CLIENT SDK  (browser-safe, required)
# Get these from: Firebase Console → Project Settings → General → Your Apps
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456


# -----------------------------------------------------------------------------
# FIREBASE — ADMIN SDK  (server-only, required)
# Get these from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key  (downloads a JSON file)
#
# FIREBASE_PRIVATE_KEY  — copy the "private_key" field from the JSON.
#   On Linux/Mac wrap in double quotes and keep the literal \n chars.
#   On Windows single-line the whole key and escape backslashes:
#     FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
# -----------------------------------------------------------------------------
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"


# -----------------------------------------------------------------------------
# PAYONEER — OAuth 2.0 Integration  (server-only, optional)
# Used by the income adapter to pull verified freelancer earnings.
# Get these from: Payoneer Developer Portal → My Applications
# Leave blank to disable Payoneer data source (platform will mark as unavailable).
# -----------------------------------------------------------------------------
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_REDIRECT_URI=http://localhost:3000/api/v1/connect/payoneer/callback


# -----------------------------------------------------------------------------
# UPWORK — OAuth 1.0a Integration  (server-only, optional)
# Used by the income adapter to pull Upwork contract earnings.
# Get these from: Upwork Developer Portal → My Apps
# Leave blank to disable Upwork data source.
# -----------------------------------------------------------------------------
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# ONFIDO — KYC / Identity Verification  (server-only, optional)
# Used to trigger real identity checks during freelancer onboarding.
# Get these from: Onfido Dashboard → API Keys
# Leave blank to run in simulation mode (KYC check will be mocked).
# -----------------------------------------------------------------------------
ONFIDO_API_KEY=
ONFIDO_WORKFLOW_ID=


# -----------------------------------------------------------------------------
# NEXT.JS — App Configuration  (server-only)
# -----------------------------------------------------------------------------
# Base URL of the deployed app — used for building absolute callback URLs.
# In development this is typically http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment — Next.js sets this automatically; listed here for clarity.
# Values: development | test | production
NODE_ENV=development
