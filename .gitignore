# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
scratch/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets stay local, example template is committed
.env
.env.local
.env.*.local
.env.production
.env.staging
# allow the example template
!.env.example

# solana keypairs — never commit private keys
/keys/
*.keypair.json

# anchor / rust build artifacts (includes program keypairs under target/deploy)
/target/
/.anchor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
